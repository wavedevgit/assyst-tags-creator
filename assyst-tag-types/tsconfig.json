{
    "compilerOptions": {
        "target": "es6",
        "module": "esnext",
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "moduleResolution": "node",
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "lib": ["es6"]
    },
    "include": ["index.d.ts"],
    "files": ["ImageScript.d.ts", "index.d.ts"]
}
